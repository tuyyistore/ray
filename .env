# ─────────────────────────────────────────────
#  WhatsApp Multi-Device Bot – Environment File
#  Copy ke .env lalu isi nilainya
# ─────────────────────────────────────────────

# Nomor HP yang akan dipasangkan (format internasional, tanpa +)
BOT_NUMBER=66841733170

# Prefix command (default titik)
PREFIX=.

# Nama bot
BOT_NAME=MyBot

# Owner number (bisa lebih dari satu, pisah koma)
OWNER_NUMBER=6283121214520

# API Nexray key (opsional, isi jika punya)
NEXRAY_KEY=

# Log level: trace | debug | info | warn | error | silent
LOG_LEVEL=info
